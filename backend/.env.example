# Server configuration
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/aether_tax

# Auth
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=1d

# Google AI (Gemini) — reference tax rate insights in dashboard
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: gemini-2.0-flash (default) or e.g. gemini-1.5-flash
# GEMINI_MODEL=gemini-1.5-flash
